# config.env

# --- Browser Settings ---
# Set the target URL for the automation
TARGET_URL=https://example.com

# Path to a JSON file containing cookies to load.
# Format: [{"name": "cookie_name", "value": "cookie_value", "domain": ".example.com", "path": "/", "secure": true, "httpOnly": true, "expiry": 1678886400}]
COOKIE_FILE=./cookies.json

# Optional: A JWT token to set in localStorage for authentication.
LOGIN_TOKEN=your_super_secret_token_here

# --- Selenium Stealth & Fingerprinting ---
# Enable persistent Chrome profile. Requires PROFILE_DIR to be set.
PERSIST_PROFILE=0
# Directory for persistent Chrome profile. Example: /Users/youruser/Library/Application Support/Google/Chrome/
PROFILE_DIR=

# Custom User Agent string.
USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/91.0.4472.124 Safari/537.36

# Window size for the browser.
WINDOW_WIDTH=1920
WINDOW_HEIGHT=1080

# Language preference for the browser.
LANG=en-US,en;q=0.9

# Override the browser's timezone. Example: America/New_York
TIMEZONE=

# Enable fingerprint detection. '1' to enable, '0' to disable.
FP_DETECT=0

# Enable fingerprint overrides. '1' to enable, '0' to disable.
# These overrides will only be applied if FP_DETECT is also enabled and the corresponding fingerprint surface is detected.
FP_WEBGL=0
FP_CANVAS=0
FP_AUDIO=0

# Custom WebGL vendor and renderer strings if FP_WEBGL is enabled.
WEBGL_VENDOR=NVIDIA
WEBGL_RENDERER=NVIDIA GeForce RTX 3080

# --- Logging ---
# Logging level (e.g., INFO, DEBUG, WARNING, ERROR).
LOG_LEVEL=INFO
